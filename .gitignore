# --- PRIVATE sensitive-data root (NEVER commit/deploy — ADR-002) ---
# The entire .autofirm/ workspace holds per-company finance models, client
# artifacts, real financials, PII, secrets, and machine-local saga/runtime state.
# It is structurally fenced out of git so it can never reach GitHub or a deploy.
.autofirm/

# --- Secrets & environment (NEVER commit) ---
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# --- Runtime state, logs, audit spool (machine-local) ---
logs/
*.log

# --- Node ---
node_modules/
dist/
build/
.next/
coverage/
*.tsbuildinfo
.turbo/

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
mutants/
*.egg-info/
.mutmut-cache
.hypothesis/

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# --- Analysis artifacts that are regenerated (keep evidence/ committed, ignore scratch) ---
evidence/_scratch/
*.tmp
